            <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-border">
              <span class="text-2xl flex-shrink-0">💉</span>
              <div>
                <p class="font-display font-bold text-ink">Vaccinations required</p>
                <p class="text-ink-soft text-sm mt-1">All boarders must be vaccinated for cat flu and feline enteritis.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-border">
              <span class="text-2xl flex-shrink-0">✂️</span>
              <div>
                <p class="font-display font-bold text-ink">Neutering requirement</p>
                <p class="text-ink-soft text-sm mt-1">Male cats over seven months old must be neutered.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ambience section -->
  <section class="py-20 bg-brand-bg">
