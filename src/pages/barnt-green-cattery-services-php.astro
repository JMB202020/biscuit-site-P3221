      <h1 class="font-display font-extrabold text-white leading-tight max-w-2xl">Cattery Services</h1>
      <p class="mt-5 text-white/80 text-lg max-w-xl leading-relaxed">We want your pets to spend their time with us in contented ease, relaxed and laid back. Here is how we make that happen.</p>
    </div>
  </section>

  <!-- Food section -->
  <section class="py-20 bg-brand-bg">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid md:grid-cols-2 gap-14 items-center">
        <div>
