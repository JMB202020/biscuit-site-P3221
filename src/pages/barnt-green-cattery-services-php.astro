        </div>
      </div>
    </div>
  </section>

  <!-- Vaccination section -->
  <section class="py-20 bg-cream border-y border-border">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid md:grid-cols-2 gap-14 items-center">
