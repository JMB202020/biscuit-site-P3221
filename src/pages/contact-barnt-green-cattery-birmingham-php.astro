          <!-- Opening hours -->
          <div class="mt-10">
            <h2 class="font-display font-extrabold text-ink text-2xl mb-5">Opening Hours</h2>
            <div class="bg-white rounded-2xl border border-border shadow-sm overflow-hidden">
              <div class="p-5 border-b border-border">
                <p class="font-display font-bold text-ink mb-1">Open by appointment</p>
                <p class="text-ink-soft text-sm">9:30am &ndash; 12:30pm and 4:30pm &ndash; 5:30pm</p>
