            <a href="/P3221/barnt-green-cattery-birmingham-boarding-fees-php" class="text-white/60 text-sm hover:text-white transition-colors">Boarding Fees</a>
            <a href="/P3221/contact-barnt-green-cattery-birmingham-php" class="text-white/60 text-sm hover:text-white transition-colors">Contact Us</a>
          </nav>
        </div>
      </div>
      <div class="mt-10 pt-8 border-t border-white/10 text-center">
        <p class="text-white/40 text-sm">&copy; 2026 Barnt Green Boarding Cattery. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
  </script>

